{
  "name": "Client",
  "module": "Operations",
  "doctype": "DocType",
  "naming_rule": "Expression",
  "autoname": "format:CLT-{###}",
  "is_submittable": 0,
  "track_changes": 1,
  "description": "FM service recipient (bank, corporation, etc.).",
  "fields": [
    {
      "fieldname": "tab_general",
      "fieldtype": "Tab Break",
      "label": "General Details"
    },
    {
      "fieldname": "client_code",
      "fieldtype": "Data",
      "label": "Client Code",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "bold": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "client_name",
      "fieldtype": "Data",
      "label": "Client Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "client_short_name",
      "fieldtype": "Data",
      "label": "Short Name"
    },
    {
      "fieldname": "sec_industry",
      "fieldtype": "Section Break",
      "label": "Industry & Classification"
    },
    {
      "fieldname": "industry",
      "fieldtype": "Select",
      "label": "Industry",
      "options": "\nBanking\nInsurance\nReal Estate\nGovernment\nHealthcare\nRetail\nOther",
      "in_standard_filter": 1
    },
    {
      "fieldname": "sla_tier",
      "fieldtype": "Select",
      "label": "SLA Tier",
      "options": "\nPlatinum\nGold\nSilver\nBronze",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "col_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "country",
      "fieldtype": "Link",
      "label": "Country",
      "options": "Country"
    },
    {
      "fieldname": "city_code",
      "fieldtype": "Link",
      "label": "City",
      "options": "CAFM City",
      "in_standard_filter": 1
    },
    {
      "fieldname": "tab_contact",
      "fieldtype": "Tab Break",
      "label": "Contact Details"
    },
    {
      "fieldname": "sec_primary",
      "fieldtype": "Section Break",
      "label": "Primary Contact"
    },
    {
      "fieldname": "primary_contact",
      "fieldtype": "Data",
      "label": "Primary Contact Name"
    },
    {
      "fieldname": "contact_phone",
      "fieldtype": "Data",
      "label": "Contact Phone"
    },
    {
      "fieldname": "col_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "contact_email",
      "fieldtype": "Data",
      "label": "Contact Email",
      "options": "Email"
    },
    {
      "fieldname": "account_manager",
      "fieldtype": "Link",
      "label": "Account Manager",
      "options": "User"
    },
    {
      "fieldname": "tab_commercial",
      "fieldtype": "Tab Break",
      "label": "Commercial"
    },
    {
      "fieldname": "sec_billing",
      "fieldtype": "Section Break",
      "label": "Billing"
    },
    {
      "fieldname": "payment_terms",
      "fieldtype": "Select",
      "label": "Payment Terms",
      "options": "\nNet 30\nNet 45\nNet 60\nNet 90\nImmediate"
    },
    {
      "fieldname": "col_break_4",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "preferred_request_mode",
      "fieldtype": "Select",
      "label": "Preferred Request Mode",
      "options": "\nPortal\nPhone\nEmail\nMobile App\nOn-Site"
    },
    {
      "fieldname": "sec_status",
      "fieldtype": "Section Break",
      "label": "Status"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "CAFM Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "CAFM User",
      "read": 1,
      "write": 0,
      "create": 0,
      "delete": 0
    }
  ],
  "search_fields": "client_name,client_short_name",
  "title_field": "client_name",
  "sort_field": "client_name",
  "sort_order": "ASC"
}