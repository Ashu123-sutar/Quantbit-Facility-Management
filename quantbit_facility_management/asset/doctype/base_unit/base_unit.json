{
    "name": "Base Unit",
    "module": "Asset",
    "doctype": "DocType",
    "naming_rule": "Expression",
    "autoname": "format:BU{#####}",
    "is_submittable": 0,
    "track_changes": 1,
    "description": "Smallest physical unit of location (workstation, counter, ATM bay). Supports QR-code scanning.",
    "fields": [
        {
            "fieldname": "tab_general",
            "fieldtype": "Tab Break",
            "label": "General Details"
        },
        {
            "fieldname": "base_unit_code",
            "fieldtype": "Data",
            "label": "Base Unit Code",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1,
            "in_standard_filter": 1,
            "bold": 1
        },
        {
            "fieldname": "col_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "base_unit_name",
            "fieldtype": "Data",
            "label": "Base Unit Name",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "sec_hierarchy",
            "fieldtype": "Section Break",
            "label": "Location Hierarchy"
        },
        {
            "fieldname": "sub_zone_code",
            "fieldtype": "Link",
            "label": "Sub Zone",
            "options": "CAFM Sub Zone",
            "reqd": 1,
            "in_standard_filter": 1,
            "search_index": 1
        },
        {
            "fieldname": "sub_zone_name",
            "fieldtype": "Data",
            "label": "Sub Zone Name",
            "fetch_from": "sub_zone_code.sub_zone_name",
            "read_only": 1
        },
        {
            "fieldname": "col_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "zone_code",
            "fieldtype": "Link",
            "label": "Zone",
            "options": "CAFM Zone",
            "fetch_from": "sub_zone_code.zone_code",
            "read_only": 1
        },
        {
            "fieldname": "property_code",
            "fieldtype": "Link",
            "label": "Property",
            "options": "CAFM Property",
            "fetch_from": "sub_zone_code.property_code",
            "read_only": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "business_type",
            "fieldtype": "Data",
            "label": "Business Type",
            "fetch_from": "zone_code.business_type",
            "read_only": 1
        },
        {
            "fieldname": "tab_location",
            "fieldtype": "Tab Break",
            "label": "Location & QR"
        },
        {
            "fieldname": "sec_gps",
            "fieldtype": "Section Break",
            "label": "GPS"
        },
        {
            "fieldname": "gps_lat",
            "fieldtype": "Float",
            "label": "GPS Latitude",
            "precision": "7"
        },
        {
            "fieldname": "col_break_3",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "gps_long",
            "fieldtype": "Float",
            "label": "GPS Longitude",
            "precision": "7"
        },
        {
            "fieldname": "sec_qr",
            "fieldtype": "Section Break",
            "label": "QR Code"
        },
        {
            "fieldname": "qr_code_ref",
            "fieldtype": "Data",
            "label": "QR Code Reference",
            "description": "Unique QR code tag affixed to the unit e.g. QR-BU10001"
        },
        {
            "fieldname": "qr_code_image",
            "fieldtype": "Attach Image",
            "label": "QR Code Image"
        },
        {
            "fieldname": "sec_status",
            "fieldtype": "Section Break",
            "label": "Status"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": "1",
            "in_list_view": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "CAFM Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0
        },
        {
            "role": "CAFM User",
            "read": 1,
            "write": 0,
            "create": 0,
            "delete": 0
        }
    ],
    "search_fields": "base_unit_name,sub_zone_code,property_code,qr_code_ref",
    "title_field": "base_unit_name",
    "sort_field": "base_unit_code",
    "sort_order": "ASC"
}