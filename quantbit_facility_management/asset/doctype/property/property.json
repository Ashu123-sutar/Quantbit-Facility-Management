{
    "name": "Property",
    "module": "Asset",
    "doctype": "DocType",
    "naming_rule": "Expression",
    "autoname": "format:P{#####}",
    "is_submittable": 0,
    "track_changes": 1,
    "description": "Physical property/building under FM contract. Top-level location entity.",
    "fields": [
        {
            "fieldname": "tab_general",
            "fieldtype": "Tab Break",
            "label": "General Details"
        },
        {
            "fieldname": "property_code",
            "fieldtype": "Data",
            "label": "Property Code",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1,
            "in_standard_filter": 1,
            "bold": 1,
            "description": "e.g. P10001"
        },
        {
            "fieldname": "col_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "property_name",
            "fieldtype": "Data",
            "label": "Property Name",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "sec_classification",
            "fieldtype": "Section Break",
            "label": "Classification"
        },
        {
            "fieldname": "property_type",
            "fieldtype": "Select",
            "label": "Property Type",
            "options": "\nHeadquarters\nBranch\nData Centre\nWarehouse\nRemote ATM Site\nOther",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "business_type",
            "fieldtype": "Select",
            "label": "Business Type",
            "options": "\nBank HQ Areas\nBank Branch Areas\nBank Staff Areas\nBank Infrastructure Areas\nBank ATM Areas\nData Centre Areas\nOther",
            "in_standard_filter": 1
        },
        {
            "fieldname": "col_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "gfa_sqm",
            "fieldtype": "Float",
            "label": "GFA (sqm)",
            "description": "Gross Floor Area in square metres"
        },
        {
            "fieldname": "floors",
            "fieldtype": "Int",
            "label": "Number of Floors"
        },
        {
            "fieldname": "tab_location",
            "fieldtype": "Tab Break",
            "label": "Location"
        },
        {
            "fieldname": "sec_hierarchy",
            "fieldtype": "Section Break",
            "label": "Area Hierarchy"
        },
        {
            "fieldname": "area_code",
            "fieldtype": "Link",
            "label": "Area",
            "options": "CAFM Area",
            "reqd": 1,
            "in_standard_filter": 1,
            "search_index": 1
        },
        {
            "fieldname": "area_name",
            "fieldtype": "Data",
            "label": "Area Name",
            "fetch_from": "area_code.area_name",
            "read_only": 1
        },
        {
            "fieldname": "col_break_3",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "city_code",
            "fieldtype": "Link",
            "label": "City",
            "options": "CAFM City",
            "fetch_from": "area_code.city_code",
            "read_only": 1
        },
        {
            "fieldname": "sec_gps",
            "fieldtype": "Section Break",
            "label": "GPS Coordinates"
        },
        {
            "fieldname": "gps_lat",
            "fieldtype": "Float",
            "label": "GPS Latitude",
            "precision": "7"
        },
        {
            "fieldname": "col_break_4",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "gps_long",
            "fieldtype": "Float",
            "label": "GPS Longitude",
            "precision": "7"
        },
        {
            "fieldname": "sec_contact",
            "fieldtype": "Section Break",
            "label": "Location Contact"
        },
        {
            "fieldname": "location_contact",
            "fieldtype": "Data",
            "label": "Location Contact"
        },
        {
            "fieldname": "contact_phone",
            "fieldtype": "Data",
            "label": "Contact Phone"
        },
        {
            "fieldname": "tab_contract",
            "fieldtype": "Tab Break",
            "label": "Contract & Client"
        },
        {
            "fieldname": "sec_client",
            "fieldtype": "Section Break",
            "label": "Client"
        },
        {
            "fieldname": "client_code",
            "fieldtype": "Link",
            "label": "Client",
            "options": "CAFM Client",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1,
            "search_index": 1
        },
        {
            "fieldname": "client_name",
            "fieldtype": "Data",
            "label": "Client Name",
            "fetch_from": "client_code.client_name",
            "read_only": 1
        },
        {
            "fieldname": "col_break_5",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "contract_code",
            "fieldtype": "Link",
            "label": "Contract",
            "options": "CAFM Contract",
            "in_standard_filter": 1
        },
        {
            "fieldname": "sec_status",
            "fieldtype": "Section Break",
            "label": "Status"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": "1",
            "in_list_view": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "CAFM Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0
        },
        {
            "role": "CAFM User",
            "read": 1,
            "write": 0,
            "create": 0,
            "delete": 0
        }
    ],
    "search_fields": "property_name,area_code,client_code",
    "title_field": "property_name",
    "sort_field": "property_code",
    "sort_order": "ASC"
}