{
    "name": "Zone",
    "module": "Asset",
    "doctype": "DocType",
    "naming_rule": "Expression",
    "autoname": "format:ZN{####}",
    "is_submittable": 0,
    "track_changes": 1,
    "description": "Floor or functional zone within a Property.",
    "fields": [
        {
            "fieldname": "tab_general",
            "fieldtype": "Tab Break",
            "label": "General Details"
        },
        {
            "fieldname": "zone_code",
            "fieldtype": "Data",
            "label": "Zone Code",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1,
            "in_standard_filter": 1,
            "bold": 1
        },
        {
            "fieldname": "col_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "zone_name",
            "fieldtype": "Data",
            "label": "Zone Name",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "sec_hierarchy",
            "fieldtype": "Section Break",
            "label": "Property Hierarchy"
        },
        {
            "fieldname": "property_code",
            "fieldtype": "Link",
            "label": "Property",
            "options": "CAFM Property",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1,
            "search_index": 1
        },
        {
            "fieldname": "property_name",
            "fieldtype": "Data",
            "label": "Property Name",
            "fetch_from": "property_code.property_name",
            "read_only": 1
        },
        {
            "fieldname": "col_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "business_type",
            "fieldtype": "Select",
            "label": "Business Type",
            "options": "\nBank HQ Areas\nBank Branch Areas\nBank Staff Areas\nBank Infrastructure Areas\nBank ATM Areas\nData Centre Areas\nOther",
            "in_standard_filter": 1
        },
        {
            "fieldname": "floor_level",
            "fieldtype": "Data",
            "label": "Floor Level",
            "description": "e.g. G, 1, 2, B1, B2, Roof"
        },
        {
            "fieldname": "sec_status",
            "fieldtype": "Section Break",
            "label": "Status"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": "1",
            "in_list_view": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "CAFM Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 0
        },
        {
            "role": "CAFM User",
            "read": 1,
            "write": 0,
            "create": 0,
            "delete": 0
        }
    ],
    "search_fields": "zone_name,property_code",
    "title_field": "zone_name",
    "sort_field": "property_code",
    "sort_order": "ASC"
}